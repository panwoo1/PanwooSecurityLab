name = "panwoo-security-lab"
main = "src/index.ts"
compatibility_date = "2026-05-09"
keep_vars = true

[assets]
directory = "../web/dist"
binding = "ASSETS"
not_found_handling = "single-page-application"
run_worker_first = true

# Configure these in Cloudflare dashboard or with Wrangler secrets/vars:
# SUPABASE_URL
# SUPABASE_ANON_KEY
